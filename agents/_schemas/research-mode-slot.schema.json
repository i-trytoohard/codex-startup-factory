{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoagents.dev/schemas/research-mode-slot.json",
  "title": "Research Mode Slot",
  "type": "object",
  "required": ["slot", "description", "configDir", "sourcesDir", "fields"],
  "properties": {
    "slot": {
      "const": "research-mode"
    },
    "description": {
      "type": "string"
    },
    "configDir": {
      "type": "string"
    },
    "sourcesDir": {
      "type": "string"
    },
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "required", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
