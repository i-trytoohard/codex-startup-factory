{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aoagents.dev/schemas/repo-local-fleet-manifest.json",
  "title": "Repo Local Fleet Manifest",
  "type": "object",
  "required": ["id", "name", "description", "agents"],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agentId", "stage"],
        "properties": {
          "agentId": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "dependsOn": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
